# Copy this file to .env and set the providers you want to use.

# Default runtime selection
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-opus-4-6

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI-compatible providers
# Examples: local Ollama, OpenRouter, Moonshot, Together, Groq, vLLM
OPENAI_API_KEY=
DEFAULT_OPENAI_COMPAT_MODEL=llama3.1:8b
DEFAULT_OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1

# Session cleanup
SESSION_TTL_MINUTES=120

# Auth gate
AUTH_REQUIRED=true
DEV_SSO_ENABLED=true
SSO_PROVIDERS=Microsoft,Google,Okta

# Access and context stores are created automatically at runtime:
# - access_control.db maps SSO-linked emails to scopes, metrics, and document tags
# - context_store.db stores memory and HR context documents used during retrieval
