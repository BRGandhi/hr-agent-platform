# Copy this file to .env before running the platform.
# This file is intentionally documented so a new engineer can understand the
# minimum configuration required to start the repo on a laptop or a server.

# -----------------------------------------------------------------------------
# LLM provider selection
# -----------------------------------------------------------------------------
# Supported values:
# - anthropic
# - openai-compatible
DEFAULT_LLM_PROVIDER=anthropic

# Default model used when DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-opus-4-6

# Anthropic credential
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# OpenAI-compatible provider settings
# -----------------------------------------------------------------------------
# Examples:
# - local Ollama
# - vLLM
# - OpenRouter
# - Together
# - Moonshot / Kimi-compatible endpoints
OPENAI_API_KEY=
DEFAULT_OPENAI_COMPAT_MODEL=llama3.1:8b
DEFAULT_OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1

# -----------------------------------------------------------------------------
# Session management
# -----------------------------------------------------------------------------
# Idle sessions are pruned in memory after this many minutes.
SESSION_TTL_MINUTES=120

# -----------------------------------------------------------------------------
# Auth shell behavior
# -----------------------------------------------------------------------------
# true  = user must sign in before using the web app
# false = app resolves the user as a local admin
AUTH_REQUIRED=true

# true  = demo SSO mode using local cookie-backed sessions
# false = disables the demo login flow; real OIDC/SAML integration is still up
#         to the deploying team to implement
DEV_SSO_ENABLED=true

# Comma-separated list of providers to render on the sign-in page
SSO_PROVIDERS=Microsoft,Google,Okta

# -----------------------------------------------------------------------------
# Optional server port
# -----------------------------------------------------------------------------
PORT=8000

# -----------------------------------------------------------------------------
# Runtime-created stores
# -----------------------------------------------------------------------------
# These are created automatically when the app starts:
# - access_control.db : maps user emails to role, scope, metrics, and doc tags
# - context_store.db  : stores memory and context documents
#
# hr_data.db is created separately by running:
#   python setup_db.py
